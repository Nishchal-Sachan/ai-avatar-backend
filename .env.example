NODE_ENV=development
PORT=3000
LOG_LEVEL=info
RATE_LIMIT_MAX=100

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/your-database-name

# JWT configuration
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d

# AI Providers

# Groq (LLM - required)
GROQ_API_KEY=your_groq_api_key

# HuggingFace (Embeddings - required)
HF_API_KEY=your_huggingface_api_key

# Deepgram (STT + TTS; same API key)
STT_PROVIDER=deepgram
DEEPGRAM_API_KEY=your_api_key
# Optional: override Aura voice model for TTS
# DEEPGRAM_TTS_MODEL=aura-2-thalia-en

# Pinecone (vector DB - required for persistent embeddings)
# Create index with dimension 384 (all-MiniLM-L6-v2) and filterable metadata: documentId, avatarId
PINECONE_API_KEY=your_api_key
PINECONE_INDEX=ai-avatar-index

# Public base URL for absolute TTS links (no trailing slash)
BASE_URL=https://ai-avatar-backend-sti8.onrender.com


# Email Configuration
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
